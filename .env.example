# PostgreSQL (docker compose maps host port 5434 -> container 5432; 5432/5433 are taken by other local projects)
POSTGRES_PORT=5434
POSTGRES_DB=movienest
POSTGRES_USER=movienest
POSTGRES_PASSWORD=movienest

DATABASE_URL="postgresql://movienest:movienest@localhost:5434/movienest?schema=public"

# Secret for signing session cookies
SESSION_SECRET="change-me-in-production"

# Production (Timeweb Cloud managed PostgreSQL) — реальные значения держать в .env,
# в панель App Platform идёт собранный DATABASE_URL вида:
# postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require&sslaccept=accept_invalid_certs

# TanStack AI: автозаполнение карточки фильма по названию
OPENAI_API_KEY="sk-..."
# OPENAI_MODEL=gpt-5.2
# OPENAI_BASE_URL=https://<ваш-прокси>/v1  # см. docs/OPENAI_PROXY.md (нужен на хостинге в РФ)
