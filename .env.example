# PostgreSQL (docker compose maps host port 5434 -> container 5432; 5432/5433 are taken by other local projects)
POSTGRES_PORT=5434
POSTGRES_DB=movienest
POSTGRES_USER=movienest
POSTGRES_PASSWORD=movienest

DATABASE_URL="postgresql://movienest:movienest@localhost:5434/movienest?schema=public"

# Secret for signing session cookies
SESSION_SECRET="change-me-in-production"
