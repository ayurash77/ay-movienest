generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  createdAt    DateTime     @default(now())
  sessions     Session[]
  ratings      Rating[]
  movies       Movie[]
  comments     Comment[]
  watchEntries WatchEntry[]
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Movie {
  id           String       @id @default(cuid())
  kind         MovieKind    @default(MOVIE)
  title        String
  year         Int
  country      String
  description  String
  posterUrl    String?
  director     String?
  genres       String[]
  durationMin  Int?
  starring     String[]
  createdById  String?
  createdBy    User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  ratings      Rating[]
  comments     Comment[]
  watchEntries WatchEntry[]

  @@index([createdAt])
  @@index([kind, createdAt])
}

enum MovieKind {
  MOVIE
  SERIES
  CARTOON
}

model Comment {
  id        String   @id @default(cuid())
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())

  @@index([movieId, createdAt])
}

enum WatchStatus {
  WATCHLIST
  WATCHED
}

model WatchEntry {
  id        String      @id @default(cuid())
  movieId   String
  movie     Movie       @relation(fields: [movieId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    WatchStatus
  updatedAt DateTime    @updatedAt
  createdAt DateTime    @default(now())

  @@unique([movieId, userId])
  @@index([userId, status])
}

model Rating {
  id        String   @id @default(cuid())
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([movieId, userId])
  @@index([createdAt])
}
