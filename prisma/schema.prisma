generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  name               String
  passwordHash       String
  role               String            @default("USER")
  createdAt          DateTime          @default(now())
  sessions           Session[]
  ratings            Rating[]
  movies             Movie[]
  comments           Comment[]
  watchEntries       WatchEntry[]
  friends            UserFriend[]      @relation("UserFriends")
  friendOf           UserFriend[]      @relation("FriendOf")
  following          UserFollow[]      @relation("UserFollowing")
  followers          UserFollow[]      @relation("UserFollowers")
  notifications      Notification[]    @relation("UserNotifications")
  actedNotifications Notification[]    @relation("NotificationActor")
  chatParticipants   ChatParticipant[]
  chatMessages       ChatMessage[]
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model UserFriend {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friendId  String
  friend    User     @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, friendId])
  @@index([userId, createdAt])
  @@index([friendId])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId, createdAt])
  @@index([followingId])
}

model Movie {
  id                String         @id @default(cuid())
  kind              MovieKind      @default(MOVIE)
  title             String
  year              Int
  country           String
  description       String
  posterUrl         String?
  trailerUrl        String?
  director          String?
  genres            String[]
  durationMin       Int?
  seasonsCount      Int?
  episodesPerSeason Int[]
  starring          String[]
  createdById       String?
  createdBy         User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  ratings           Rating[]
  comments          Comment[]
  watchEntries      WatchEntry[]
  notifications     Notification[]

  @@index([createdAt])
  @@index([kind, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?     @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  movieId   String?
  movie     Movie?    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
  @@index([actorId])
  @@index([movieId])
}

model ChatThread {
  id           String            @id @default(cuid())
  privateKey   String?           @unique
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([updatedAt])
}

model ChatParticipant {
  id         String     @id @default(cuid())
  threadId   String
  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?
  createdAt  DateTime   @default(now())

  @@unique([threadId, userId])
  @@index([userId])
  @@index([userId, lastReadAt])
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime   @default(now())

  @@index([threadId, createdAt])
  @@index([userId])
}

enum MovieKind {
  MOVIE
  SERIES
  CARTOON
}

model Comment {
  id        String   @id @default(cuid())
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())

  @@index([movieId, createdAt])
}

enum WatchStatus {
  WATCHLIST
  WATCHED
}

model WatchEntry {
  id        String      @id @default(cuid())
  movieId   String
  movie     Movie       @relation(fields: [movieId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    WatchStatus
  updatedAt DateTime    @updatedAt
  createdAt DateTime    @default(now())

  @@unique([movieId, userId])
  @@index([userId, status])
}

model Rating {
  id        String   @id @default(cuid())
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([movieId, userId])
  @@index([createdAt])
}
